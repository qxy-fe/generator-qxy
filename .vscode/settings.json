{
  "oxc.enable": true,
  "eslint.enable": false,
  "prettier.enable": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "files.associations": {
    "*.yml.ejs": "yaml",
    "*.md.ejs": "markdown",
    "*.json.ejs": "json",
    "*.js.ejs": "plaintext",
    "*.ts.ejs": "plaintext",
    "LICENSE.ejs": "plaintext",
    ".gitignore.ejs": "ignore"
  },
  "typescript.experimental.useTsgo": true,
  "cSpell.allowCompoundWords": true,
  "cSpell.words": [
    "bumpp",
    "cdnurl",
    "changelogithub",
    "cnpm",
    "dprint",
    "execa",
    "lcov",
    "Metas",
    "njsproj",
    "npmrc",
    "ntnyq",
    "ntvs",
    "Oxfmt",
    "oxfmtrc",
    "oxlint",
    "oxlintrc",
    "pnpm",
    "stackblitzrc",
    "svgo",
    "tsbuildinfo",
    "tsdown",
    "vite",
    "vitepress",
    "vitest",
    "vuepress",
    "yarnrc"
  ]
}
