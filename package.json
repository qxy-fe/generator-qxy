{
  "name": "generator-qxy",
  "version": "0.21.0",
  "keywords": [
    "yeoman-generator"
  ],
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": "qxy-fe/generator-qxy",
  "files": [
    "generators"
  ],
  "type": "module",
  "main": "./generators/app/index.js",
  "exports": "./generators/app/index.js",
  "scripts": {
    "build": "tsdown",
    "copy": "copyfiles -a -u 1 -V src/*/templates/**/** generators",
    "dev": "tsdown --watch src",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check build lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "nanospinner": "^1.2.2",
    "sort-package-json": "^3.6.1",
    "yeoman-environment": "^6.0.0",
    "yeoman-generator": "^8.0.0"
  },
  "devDependencies": {
    "@generator-qxy/tester": "workspace:*",
    "@types/node": "^25.3.3",
    "@types/yeoman-assert": "^3.1.4",
    "@typescript/native-preview": "7.0.0-dev.20260303.1",
    "@yeoman/types": "^1.10.3",
    "bumpp": "^10.4.1",
    "copyfiles": "^2.4.1",
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tinyexec": "^1.0.2",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yeoman-assert": "^3.1.1",
    "yeoman-test": "^11.3.1"
  },
  "resolutions": {
    "mem-fs": "^4.1.4"
  },
  "nano-staged": {
    "*.{js,ts,tsx,mjs}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=20.12.0"
  }
}
